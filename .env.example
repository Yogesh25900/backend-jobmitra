# Application Port
PORT=5000

# MongoDB Connection URL
MONGODB_URL=mongodb://localhost:27017/jobmitra_db

# JWT Secret Key (replace in production)
JWT_SECRET=your-super-secret-jwt-key-here

# Google OAuth Web Client ID (used to verify Google credential JWTs)
# Keep this equal to the client ID used by your frontend Google OAuth provider
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
